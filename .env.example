# Copie este arquivo para .env e preencha os valores (nunca commite o .env)

# Obrigatório — connection string do Supabase
# Formato: postgresql://postgres:[senha]@db.[projeto].supabase.co:5432/postgres?sslmode=require
DATABASE_URL=

# Chave de sessão Flask — gere com: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

# Credenciais do usuário admin criado no primeiro boot
APP_USERNAME=admin
APP_PASSWORD=barril2025

# Só ativar em desenvolvimento local
FLASK_DEBUG=false
